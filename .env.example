# ╔══════════════════════════════════════════════════════╗
# ║  OpenCode + OpenChamber Deployment Configuration    ║
# ╚══════════════════════════════════════════════════════╝
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── AI Provider API Keys (fill in the ones you use) ──

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
GEMINI_API_KEY=

# ── OpenCode Server Auth ──

OPENCODE_SERVER_PASSWORD=changeme-use-a-strong-password
OPENCODE_SERVER_USERNAME=opencode

# ── OpenChamber ──

# Password to protect the OpenChamber web UI (REQUIRED)
OPENCHAMBER_UI_PASSWORD=changeme-use-a-strong-password

# Port to expose OpenChamber on the host (default: 3000)
OPENCHAMBER_PORT=3000

# Public origin for WebSocket origin validation behind reverse proxy
# Set this to your external URL (e.g., https://o.b68works.com)
OPENCHAMBER_PUBLIC_ORIGIN=https://o.b68works.com
