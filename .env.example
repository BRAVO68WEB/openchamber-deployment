# ╔══════════════════════════════════════════════════════╗
# ║  OpenCode + OpenChamber Deployment Configuration    ║
# ╚══════════════════════════════════════════════════════╝
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── AI Provider API Keys (fill in the ones you use) ──

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
GEMINI_API_KEY=

# ── OpenCode Server Auth ──

OPENCODE_SERVER_PASSWORD=changeme-use-a-strong-password
OPENCODE_SERVER_USERNAME=opencode

# ── OpenChamber ──

# Password to protect the OpenChamber web UI (REQUIRED)
OPENCHAMBER_UI_PASSWORD=changeme-use-a-strong-password

# Port to expose Nginx reverse proxy on the host (default: 80)
NGINX_PORT=80
